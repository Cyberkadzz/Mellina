  transform: translateX(30px);
  transition: opacity 0.6s cubic-bezier(0.19, 1, 0.22, 1), transform 0.6s cubic-bezier(0.19, 1, 0.22, 1), color var(--transition-smooth);
  transition-delay: calc(0.1s * var(--i));
  display: inline-block;
  width: max-content;
}

.mobile-nav-drawer.open .mobile-nav-links a {
  opacity: 1;
  transform: translateX(0);
}

.mobile-nav-links a:hover {
  color: var(--color-accent);
}

