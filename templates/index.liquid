}

.mobile-nav-overlay.open {
  opacity: 1;
  pointer-events: auto;
}

/* Mobile Nav Drawer (Sidebar) */
.mobile-nav-drawer {
  position: fixed;
  top: 0;
  right: 0;
  height: 100svh;
  width: 320px;
  max-width: 85vw;
  background-color: var(--color-secondary); /* Elegant Nude */
  z-index: 101;
  display: flex;
  flex-direction: column;
  padding: 80px 40px;
  transform: translateX(100%);
  transition: transform var(--transition-smooth);
  box-shadow: -10px 0 30px rgba(0,0,0,0.1);
}

.mobile-nav-drawer.open {
  transform: translateX(0);
}

.mobile-nav-close {
  position: absolute;
  top: 24px;
  right: 24px;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--color-foreground);
  padding: 16px;
  transition: transform var(--transition-smooth);
}

.mobile-nav-close:hover {
  transform: rotate(90deg) scale(1.1);
}

.mobile-nav-links {
  display: flex;
  flex-direction: column;
  gap: 32px;
  text-align: left;
}

.mobile-nav-links a {
  font-size: 1.25rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  font-weight: 300;
  color: var(--color-foreground);
