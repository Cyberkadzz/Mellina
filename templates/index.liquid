<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;500&family=Montserrat:wght@200;300;400;500&display=swap');

@font-face {
  font-family: 'CameraPlainVariable';
  src: url('https://cdn.gpteng.co/mcp-widgets/v1/fonts/CameraPlainVariable.woff2') format('woff2');
  font-weight: 100 900;
  font-style: normal;
  font-display: swap;
}

:root {
  /* Colors */
  --color-background: #FCF9F8; /* Soft warm white */
  --color-secondary: #EADDD7; /* Rich Elegant Nude */
  --color-foreground: #0A0A0A;
  --color-accent: #64554D; /* Original Darker Brown */
  --color-brown: #64554D; /* Original Darker Brown */
  --color-muted: #7A7A7A;
  
  /* Typography */
  --font-main: 'Inter', sans-serif;
  --font-display: 'Inter', sans-serif;
  --font-logo: 'Montserrat', sans-serif;
  
  /* Metrics & Motion */
  --container-width: 1400px;
  --header-height: 80px;
  --transition-smooth: 0.8s cubic-bezier(0.19, 1, 0.22, 1);
  --transition-slow: 1.6s cubic-bezier(0.16, 1, 0.3, 1);
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
  font-size: 16px;
  background-color: var(--color-background);
}

body {
  font-family: var(--font-main);
  background-color: var(--color-background);
  color: var(--color-foreground);
  line-height: 1.6;
  overflow-x: hidden;
  font-weight: 300;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

::selection {
  background: var(--color-accent);
  color: #fff;
}

a {
  text-decoration: none;
  color: inherit;
}

ul {
  list-style: none;
}

/* Animations & Reveal Effects */
.fade-up {
  opacity: 0;
  transform: translateY(40px);
  transition: opacity var(--transition-slow), transform var(--transition-slow);
}

.fade-up.visible {
  opacity: 1;
  transform: translateY(0);
}

.reveal-text {
  clip-path: polygon(0 0, 100% 0, 100% 100%, 0% 100%);
  opacity: 0;
  transform: translateY(120%);
  transition: opacity var(--transition-slow), transform var(--transition-slow);
}

.reveal-text.visible {
  opacity: 1;
  transform: translateY(0);
}

.delay-1 { transition-delay: 0.15s; }
.delay-2 { transition-delay: 0.3s; }
.delay-3 { transition-delay: 0.45s; }
.delay-4 { transition-delay: 0.6s; }

/* Utilities */
.container {
  width: 100%;
  max-width: var(--container-width);
  margin: 0 auto;
  padding: 0 32px; /* Increased margin/padding to unglue from corners */
}

@media (min-width: 768px) {
  .container {
    padding: 0 56px;
  }
}

.text-sm { font-size: 0.875rem; }
.text-xs { font-size: 0.75rem; }

.uppercase-spaced {
  font-family: var(--font-logo);
  text-transform: uppercase;
  letter-spacing: 0.15em;
  font-size: 0.75rem;
  font-weight: 400;
}

.mt-8 { margin-top: 2rem; }

.text-center { text-align: center; }
.max-w-3xl { max-width: 800px; }
.mx-auto { margin-left: auto; margin-right: auto; }

/* Top Bar */
.top-bar {
  background-color: #DEB4A9; /* Rosa nude mais forte */
  color: var(--color-foreground); /* Dark text for readability */
  text-align: center;
  padding: 12px 32px;
  position: relative;
  z-index: 50;
  overflow: hidden;
}

.top-bar p {
  font-family: var(--font-main);
  font-size: 0.85rem;
  font-weight: 300;
}

.top-bar-close {
  position: absolute;
  right: 24px;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  cursor: pointer;
  color: var(--color-foreground);
  opacity: 0.5;
  transition: opacity var(--transition-smooth);
  padding: 8px; /* Easier to click on mobile */
}

.top-bar-close:hover {
  opacity: 1;
}

/* Header */
.header {
  position: fixed;
  top: 38px;
  left: 0;
  width: 100%;
  z-index: 40;
  background-color: rgba(253, 252, 249, 0.65); /* More transparent for true frosted glass */
  backdrop-filter: blur(12px) saturate(180%);
  -webkit-backdrop-filter: blur(12px) saturate(180%);
  transition: background-color var(--transition-smooth), top var(--transition-smooth), padding var(--transition-smooth);
  border-bottom: 1px solid rgba(10, 10, 10, 0.05);
  padding: 8px 0;
}

.header.scrolled {
  background-color: rgba(253, 252, 249, 0.85); /* Slightly more solid when scrolling */
  top: 0;
  padding: 0;
}

.header-main {
  height: var(--header-height);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-nav-icons {
  display: flex;
  align-items: center;
  gap: 16px;
  flex: 1;
}

@media (min-width: 768px) {
  .header-nav-icons {
    gap: 24px;
  }
}

.header-nav-icons.right {
  justify-content: flex-end;
}

.header-nav-icons button, .header-nav-icons a {
  background: none;
  border: none;
  cursor: pointer;
  color: var(--color-foreground);
  transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), color 0.4s;
  display: flex;
  align-items: center;
  padding: 8px;
}

.header-nav-icons button:hover, .header-nav-icons a:hover {
  color: var(--color-accent);
}

.logo {
  font-family: var(--font-logo);
  font-size: 1.5rem;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: var(--color-foreground);
  font-weight: 300;
  flex: 1;
  text-align: center;
}

@media (min-width: 768px) {
  .logo {
    font-size: 1.75rem;
  }
}

/* Desktop Navigation */
.desktop-nav {
  display: none;
  border-top: 1px solid rgba(10, 10, 10, 0.05);
  padding: 16px 0;
}

@media (min-width: 992px) {
  .desktop-nav {
    display: block;
  }
}

.nav-links {
  display: flex;
  justify-content: center;
  gap: 40px;
}

.nav-links a {
  font-family: var(--font-logo);
  font-size: 0.85rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  font-weight: 400;
  color: var(--color-muted);
  position: relative;
  transition: color var(--transition-smooth);
}

.nav-links a:hover {
  color: var(--color-foreground);
}

/* Mobile Menu Toggle */
.mobile-menu-toggle {
  display: block;
}

@media (min-width: 768px) {
  .mobile-menu-toggle {
    display: none;
  }
}

.hidden-mobile {
  display: none !important;
}

@media (min-width: 768px) {
  .hidden-mobile {
    display: flex !important;
  }
}

/* Hero Slider */
.hero-slider {
  position: relative;
  width: 100%;
  height: 100svh; /* Better for mobile devices */
  overflow: hidden;
  background-color: var(--color-brown);
}

.slides {
  position: relative;
  width: 100%;
  height: 100%;
}

.slide {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  visibility: hidden;
  transition: opacity 1.2s ease-in-out, visibility 1.2s;
}

.slide.active {
  opacity: 1;
  visibility: visible;
  z-index: 1;
}

.slide .hero-bg {
  position: absolute;
  inset: 0;
  z-index: -1;
  overflow: hidden;
}

.slide .hero-bg img {
  width: 100%;
  height: 120%;
  object-fit: cover;
  object-position: center 30%;
  transform: translateY(-10%);
  will-change: transform;
}

.slide .hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(138, 123, 116, 0.8) 0%, rgba(138, 123, 116, 0.2) 60%, transparent 100%); /* Adjusted overlay to blend with brown */
}

.slide .container.relative {
  position: relative;
  height: 100%;
  display: flex;
  align-items: flex-end;
  padding-bottom: 120px; /* Un-glue from bottom on mobile */
  padding-top: 160px;
  z-index: 10;
}

.hero-content {
  color: #fff;
  max-width: 800px;
}

.hero-subtitle {
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 24px;
}

.hero-title {
  font-family: var(--font-display);
  font-size: clamp(3rem, 8vw, 6rem);
  line-height: 1.1;
  font-weight: 200; /* extralight */
  letter-spacing: 0.025em; /* tracking-wide */
  margin-bottom: 24px;
}

.hero-desc {
  color: rgba(255, 255, 255, 0.9);
  font-size: clamp(1rem, 3vw, 1.125rem); /* Better mobile scaling */
  margin-bottom: 40px;
  font-weight: 300;
  max-width: 500px;
}

.slider-controls {
  position: absolute;
  bottom: 120px;
  right: 56px;
  z-index: 20;
  display: none;
  gap: 16px;
}

@media (min-width: 768px) {
  .slider-controls {
    display: flex;
  }
}

.slider-controls button {
  background: rgba(255,255,255,0.05);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.15);
  color: #fff;
  width: 56px;
  height: 56px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all var(--transition-smooth);
}

.slider-controls button:hover {
  background: rgba(255,255,255,0.2);
  transform: scale(1.05);
}

.slider-dots {
  position: absolute;
  bottom: 40px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 20;
  display: flex;
  gap: 12px;
}

.dot {
  width: 40px;
  height: 3px;
  background: rgba(255,255,255,0.2);
  cursor: pointer;
  transition: background var(--transition-smooth);
}

.dot.active {
  background: var(--color-accent); /* Vibrant active dot */
}

.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background-color: var(--color-background);
  color: var(--color-foreground);
  padding: 16px 32px;
  font-size: 0.9rem;
  text-decoration: none;
  transition: all var(--transition-smooth);
  position: relative;
  overflow: hidden;
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
}

.btn-primary::before {
  content: '';
  position: absolute;
  inset: 0;
  background-color: var(--color-accent);
  transform: translateY(100%);
  transition: transform var(--transition-smooth);
  z-index: 0;
}

.btn-primary:hover::before {
  transform: translateY(0);
}

.btn-primary:hover {
  color: #fff;
  box-shadow: 0 15px 40px rgba(10, 10, 10, 0.2); /* Deep elegant shadow */
}

.btn-primary span, .btn-primary svg {
  position: relative;
  z-index: 1;
  transition: transform var(--transition-smooth);
}

.btn-primary:hover svg {
  transform: translateX(6px);
}

/* Features */
.features {
  border-bottom: 1px solid rgba(10, 10, 10, 0.05);
  padding: 40px 0;
  background-color: var(--color-secondary); /* Use Nude here */
}

.features-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 32px;
}

@media (min-width: 768px) {
  .features-grid {
    gap: 80px;
  }
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 16px;
}

.feature-item svg {
  color: var(--color-accent);
}

.feature-item span {
  font-size: 0.6875rem;
  letter-spacing: 0.15em;
  color: var(--color-muted);
  text-transform: uppercase;
}

/* Marquee */
.marquee-section {
  background-color: var(--color-brown); /* Replaced black with brown */
  color: var(--color-background);
  padding: 24px 0;
  overflow: hidden;
  white-space: nowrap;
}

.marquee-content {
  display: inline-block;
  animation: marquee 25s linear infinite;
  will-change: transform;
}

@keyframes marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

.marquee-content span {
  font-size: 0.75rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  padding-right: 80px;
}

/* Highlights */
.highlights {
  padding: 80px 0;
  background-color: var(--color-background);
}

@media (min-width: 768px) {
  .highlights {
    padding: 100px 0;
  }
}

.highlights-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 40px;
  border-bottom: 1px solid rgba(10,10,10,0.05);
  padding-bottom: 24px;
}

@media (min-width: 768px) {
  .highlights-header {
    margin-bottom: 80px;
  }
}

.highlights-title-small {
  color: var(--color-accent);
  margin-bottom: 16px;
}

.highlights-title,
.about-title {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 200; /* extralight */
  letter-spacing: 0.025em; /* tracking-wide */
  line-height: 1.2;
}

.view-all {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  color: var(--color-foreground);
  transition: gap var(--transition-smooth), color var(--transition-smooth);
  font-size: 0.875rem;
}

.view-all:hover {
  gap: 20px;
  color: var(--color-accent);
}

.highlights-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
  margin-top: 40px;
}

@media (min-width: 768px) {
  .highlights-grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
}

.highlight-item {
  position: relative;
  aspect-ratio: 4/5;
  overflow: hidden;
  border-radius: 4px;
}

.highlight-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform var(--transition-slow);
}

.highlight-item:hover img {
  transform: scale(1.05);
}

.products-empty {
  text-align: center;
  padding: 80px 0;
  color: var(--color-muted);
}

/* Quote Section */
.quote-section {
  background-color: var(--color-secondary);
  color: var(--color-foreground);
  padding: 80px 0;
  text-align: center;
}

@media (min-width: 768px) {
  .quote-section {
    padding: 100px 0;
  }
}

.quote-divider {
  width: 60px;
  height: 1px;
  background-color: var(--color-accent);
  margin: 0 auto 40px;
}

.quote-divider.bottom {
  margin: 40px auto 0;
}

.quote-text {
  font-family: var(--font-display);
  font-size: clamp(1.5rem, 4vw, 2.5rem);
  line-height: 1.4;
  font-weight: 200; /* extralight */
  color: var(--color-foreground);
  max-width: 800px;
  margin: 0 auto;
  letter-spacing: 0.025em; /* tracking-wide */
  padding: 0 20px;
}

/* About Section */
.about-section {
  padding: 80px 0;
  background-color: var(--color-background);
}

@media (min-width: 768px) {
  .about-section {
    padding: 100px 0;
  }
}

.about-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 40px;
  align-items: center;
}

@media (min-width: 1024px) {
  .about-grid {
    grid-template-columns: 1fr 1fr;
    gap: 140px;
  }
}

.about-image-wrapper {
  position: relative;
  overflow: hidden;
  border-radius: 4px;
}

.about-image {
  aspect-ratio: 4/5;
  overflow: hidden;
}

.about-image img {
  width: 100%;
  height: 120%;
  object-fit: cover;
  object-position: center 20%;
  transform: translateY(-10%);
  will-change: transform;
}

.about-subtitle {
  color: var(--color-accent);
  margin-bottom: 16px;
}

.about-desc {
  color: var(--color-muted);
  margin-bottom: 32px;
  font-size: 1.05rem;
  line-height: 1.9;
  font-weight: 300;
}

.btn-outline {
  display: inline-flex;
  align-items: center;
  gap: 16px;
  border: 1px solid rgba(10, 10, 10, 0.15);
  padding: 16px 40px;
  transition: all var(--transition-smooth);
  position: relative;
  overflow: hidden;
}

.btn-outline::before {
  content: '';
  position: absolute;
  inset: 0;
  background-color: var(--color-foreground);
  transform: translateY(100%);
  transition: transform var(--transition-smooth);
  z-index: 0;
}

.btn-outline:hover::before {
  transform: translateY(0);
}

.btn-outline:hover {
  color: var(--color-background);
  border-color: var(--color-foreground);
}

.btn-outline span, .btn-outline svg {
  position: relative;
  z-index: 1;
  transition: transform var(--transition-smooth);
}

.btn-outline:hover svg {
  transform: translateX(6px);
}

/* Instagram Section */
.instagram-section {
  padding: 80px 0;
  text-align: center;
  background-color: var(--color-background);
}

@media (min-width: 768px) {
  .instagram-section {
    padding: 100px 0;
  }
}

.instagram-title {
  color: var(--color-accent);
  margin-bottom: 16px;
}

.instagram-handle {
  font-size: clamp(2rem, 6vw, 4rem);
  font-weight: 200;
  transition: color var(--transition-smooth), transform var(--transition-smooth);
  display: inline-block;
  color: var(--color-foreground);
}

.instagram-handle:hover {
  color: var(--color-accent);
  transform: translateY(-4px);
}

/* Footer */
@keyframes gradientFooter {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

.footer {
  background: linear-gradient(270deg, var(--color-brown), #3a312c, var(--color-foreground), var(--color-brown));
  background-size: 300% 300%;
  animation: gradientFooter 15s ease infinite;
  color: var(--color-background);
}

.footer-newsletter {
  border-bottom: 1px solid rgba(253, 252, 249, 0.1);
  padding: 60px 0;
}

@media (min-width: 768px) {
  .footer-newsletter {
    padding: 100px 0;
  }
}

.newsletter-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40px;
  max-width: 1000px;
  margin: 0 auto;
}

@media (min-width: 768px) {
  .newsletter-content {
    flex-direction: row;
    justify-content: space-between;
  }
}

.newsletter-text {
  text-align: center;
}

@media (min-width: 768px) {
  .newsletter-text {
    text-align: left;
  }
}

.newsletter-title {
  font-size: clamp(1.5rem, 3vw, 2.5rem);
  font-weight: 200;
  margin-bottom: 12px;
}

.newsletter-desc {
  color: rgba(253, 252, 249, 0.6);
  font-weight: 300;
}

.newsletter-form {
  display: flex;
  width: 100%;
  position: relative;
}

@media (min-width: 768px) {
  .newsletter-form {
    width: 400px;
  }
}

.newsletter-input {
  flex: 1;
  background-color: transparent;
  border: none;
  border-bottom: 1px solid rgba(253, 252, 249, 0.3);
  padding: 16px 0;
  font-family: var(--font-main);
  font-size: 1.05rem;
  color: var(--color-background);
  outline: none;
  transition: border-color var(--transition-smooth);
}

.newsletter-input:focus {
  border-color: var(--color-accent);
}

.newsletter-btn {
  background: transparent;
  color: var(--color-accent);
  border: none;
  padding: 0 16px;
  cursor: pointer;
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  transition: transform var(--transition-smooth);
}

.newsletter-btn:hover {
  transform: translateY(-50%) translateX(6px);
}

.footer-links {
  padding: 60px 0;
}

@media (min-width: 768px) {
  .footer-links {
    padding: 120px 0;
  }
}

.footer-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 48px;
  text-align: center;
}

@media (min-width: 768px) {
  .footer-grid {
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 60px;
    text-align: left;
  }
}

.footer-brand .brand-name {
  font-size: 1.5rem;
  font-weight: 300;
  letter-spacing: 0.35em;
  margin-bottom: 24px;
}

.footer-brand p {
  color: rgba(253, 252, 249, 0.6);
  margin-bottom: 32px;
  max-width: 300px;
  line-height: 1.8;
  margin-left: auto;
  margin-right: auto;
}

@media (min-width: 768px) {
  .footer-brand p {
    margin-left: 0;
    margin-right: 0;
  }
}

.social-icons {
  display: flex;
  gap: 24px;
  justify-content: center;
}

@media (min-width: 768px) {
  .social-icons {
    justify-content: flex-start;
  }
}

.social-icons a {
  color: rgba(253, 252, 249, 0.6);
  transition: color var(--transition-smooth), transform var(--transition-smooth);
  display: inline-block;
}

.social-icons a:hover {
  color: var(--color-accent);
  transform: translateY(-4px);
}

.footer-col h4 {
  color: rgba(253, 252, 249, 0.4);
  margin-bottom: 24px;
  letter-spacing: 0.1em;
}

.footer-col nav {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.footer-col a {
  color: var(--color-background);
  opacity: 0.7;
  transition: opacity var(--transition-smooth), transform var(--transition-smooth), color var(--transition-smooth);
  display: inline-block;
  transform-origin: center;
}

@media (min-width: 768px) {
  .footer-col a {
    transform-origin: left;
  }
}

.footer-col a:hover {
  opacity: 1;
  transform: translateX(4px);
  color: var(--color-accent);
}

.footer-bottom {
  border-top: 1px solid rgba(253, 252, 249, 0.1);
  padding: 32px 0;
}

.footer-bottom-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}

