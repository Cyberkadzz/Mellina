/* Mobile Nav Overlay (Backdrop) */
.mobile-nav-overlay {
  position: fixed;
  inset: 0;
  background-color: rgba(10, 10, 10, 0.4);
  backdrop-filter: blur(4px);
  z-index: 100;
  opacity: 0;
